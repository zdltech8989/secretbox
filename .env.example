# ============ 数据库配置 ============
# 数据库类型: sqlite 或 mysql
DB_TYPE=sqlite

# SQLite 配置
SQLITE_PATH=./data/secretbox.db

# MySQL 配置 (当 DB_TYPE=mysql 时生效)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=secretbox
MYSQL_PASSWORD=secretbox
MYSQL_DATABASE=secretbox

# MySQL root 密码 (仅用于 docker-compose)
MYSQL_ROOT_PASSWORD=root_secretbox

# ============ 应用配置 ============
# 应用端口
APP_PORT=9000

# 主密码
MASTER_PASSWORD=changeme

# JWT 配置
JWT_SECRET=secretbox-jwt-secret-change-me
JWT_EXPIRE_MINUTES=1440

# KDF 迭代次数
KDF_ITERATIONS=100000

# ============ 数据目录 (用于 Docker 挂载) ============
# 应用数据目录 (SQLite 数据库、上传文件等)
DATA_DIR=./data

# MySQL 数据目录
MYSQL_DATA_DIR=./mysql_data

# ============ Nginx 配置 (可选) ============
NGINX_PORT=80
NGINX_SSL_PORT=443
